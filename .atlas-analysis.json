  "keyFeatures": [
    "Zero dependencies, lightweight wallet connector",
    "Secure sandboxed execution environment for wallet code",
    "Easily updatable wallets via manifest system",
    "Support for 10+ NEAR wallets including HOT, Meteor, MyNearWallet",
    "WalletConnect integration for mobile wallets",
    "Injected wallet support for browser extensions",
    "Sign messages, transactions, and delegate actions",
    "Event-driven architecture for wallet state changes",
    "Plugin system for extending wallet functionality",
    "Network switching between mainnet and testnet"
  ],
  "publicApiSurface": [
    "NearConnector - Main connector class",
    "SandboxWallet - Sandboxed wallet implementation",
    "InjectedWallet - Browser extension wallet implementation",
    "ParentFrameWallet - Parent frame wallet implementation",
    "connect() - Initialize wallet connection",
    "disconnect() - Disconnect from wallet",
    "wallet() - Get current wallet instance",
    "signIn() - Sign in to wallet",
    "signInAndSignMessage() - Sign in with message signing",
    "signOut() - Sign out from wallet",
    "signMessage() - Sign arbitrary message",
    "signAndSendTransaction() - Sign and send transaction",
    "signAndSendTransactions() - Sign and send multiple transactions",
    "signDelegateActions() - Sign delegate actions",
    "getAccounts() - Get connected accounts",
    "on() - Listen to events",
    "use() - Apply wallet plugin",
    "nearActionsToConnectorActions() - Convert NEAR API actions",
    "WalletManifest - Wallet configuration type",
    "NearWalletBase - Base wallet interface",
    "SignMessageParams - Message signing parameters",
    "SignedMessage - Signed message result",
    "ConnectorAction - Transaction action types"
  ]
}
